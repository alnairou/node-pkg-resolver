---
import HeaderLink from './HeaderLink.astro';
const locales = ['pl', 'en', 'et', 'de', 'he', 'ru', 'ua', 'ko', 'ja', 'zh-tw'];
const currentLang = Astro.currentLocale || 'pl';

const getLocalizedPath = (locale: string) => {
  const cleanPath = Astro.url.pathname.replace(/^\/(en|et|de|he|ru|ua|ko|ja|zh-tw)\//, '/');
  return locale === 'pl' ? cleanPath : `/${locale}${cleanPath.startsWith('/') ? cleanPath : '/' + cleanPath}`;
};

const langNames = {
  pl: 'Polski', en: 'English', et: 'Eesti', de: 'Deutsch',
  he: 'עברית', ru: 'Русский', ua: 'Українська',
  ko: '한국어', ja: '日本語', 'zh-tw': '繁體中文'
};
---

<header class="header" role="banner">
  <nav class="nav-container">
    <div class="logo-wrapper">
      <a href={getLocalizedPath(currentLang)} class="logo-link" aria-label="ALNAIR OU Home">
        <img src="/logo.svg" alt="ALNAIR OU" class="logo-img" aria-hidden="true" />
      </a>
    </div>

    <div class="nav-links desktop-only">
      <HeaderLink href={getLocalizedPath(currentLang)}>Home</HeaderLink>
      <HeaderLink href={getLocalizedPath(currentLang).replace(/\/$/, '') + "/about"}>O nas</HeaderLink>

      <div class="lang-dropdown">
        <button class="lang-btn" aria-haspopup="true">{currentLang.toUpperCase()} ▼</button>
        <div class="dropdown-content shadow-2xl">
          {locales.map((loc) => (
            <a href={getLocalizedPath(loc)} class={loc === 'he' ? 'rtl-text' : ''}>
              <span class="lang-code">{loc.toUpperCase()}</span> — {langNames[loc]}
            </a>
          ))}
        </div>
      </div>
    </div>
    <button id="menu-toggle" class="mobile-only">MENU</button>
  </nav>

  <div id="mobile-menu" class="mobile-menu hidden">
    <div class="mobile-nav-links">
      <a href={getLocalizedPath(currentLang)}>Home</a>
      <a href={getLocalizedPath(currentLang).replace(/\/$/, '') + "/about"}>O nas</a>
    </div>
    <div class="mobile-langs">
      {locales.map((loc) => <a href={getLocalizedPath(loc)} class="mobile-lang-item">{loc.toUpperCase()}</a>)}
    </div>
  </div>
</header>

<style>
  .header { background: #020617; position: sticky; top: 0; z-index: 1000; border-bottom: 2px solid #1e293b; }
  .nav-container { max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0.2rem 1.5rem; }
  .logo-img { height: 85px; width: auto; filter: brightness(0) invert(1); transition: transform 0.3s ease; }
  .logo-img:hover { transform: scale(1.05); }
  .nav-links { display: flex; align-items: center; gap: 2.5rem; }
  .lang-btn { background: #1e293b; color: white; border: 2px solid #334155; padding: 0.5rem 1.2rem; border-radius: 6px; font-weight: 800; font-size: 0.85rem; cursor: pointer; }
  .dropdown-content { display: none; position: absolute; right: 0; background: #0f172a; min-width: 240px; border: 1px solid #334155; border-radius: 8px; margin-top: 8px; }
  .dropdown-content a { color: white; padding: 14px 20px; text-decoration: none; display: block; border-bottom: 1px solid #1e293b; }
  .lang-dropdown:hover .dropdown-content { display: block; }
  .lang-code { color: #3b82f6; font-weight: 900; }
  .rtl-text { direction: rtl; text-align: right; }
  .mobile-only { display: none; background: #3b82f6; color: white; border: none; padding: 0.6rem 1.2rem; font-weight: bold; border-radius: 4px; }
  .mobile-menu { background: #020617; position: absolute; width: 100%; left: 0; border-bottom: 4px solid #3b82f6; }
  .mobile-langs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; padding: 1.5rem; }
  .mobile-lang-item { background: #1e293b; color: white; text-align: center; padding: 10px; font-size: 0.75rem; border-radius: 4px; text-decoration: none; }
  .hidden { display: none; }
  @media (max-width: 950px) { .desktop-only { display: none; } .mobile-only { display: block; } .logo-img { height: 60px; } }
</style>

<script>
  const init = () => {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
