---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';

// Dane SEO dla strony O nas (wersja polska)
const title = "O ALNAIR OU";
const description = "Strategic Intelligence & Lobbying - Specjalistyczne wsparcie operacyjne w sektorze Defence i Intelligence.";
---

<BaseLayout title={title} description={description}>
    <div class="content-wrapper prose max-w-none text-slate-800">
        <p class="lead-text font-bold text-blue-600 uppercase tracking-widest mb-4">
            Global Strategic Intelligence & Lobbying
        </p>
        
        <h2 class="text-3xl font-black mb-6 text-slate-900 uppercase">
            Nasza Misja i Kompetencje
        </h2>

        <p class="mb-6">
            <strong>ALNAIR OU</strong> z siedzibą w Tallinnie (Estonia) to niezależny hub operacyjny, 
            powołany do świadczenia specjalistycznych usług w zakresie wywiadu rynkowego, 
            analizy ryzyka geopolitycznego oraz lobbingu strategicznego. Nasze działania koncentrują się 
            na sektorach krytycznych: <strong>Defence, Cybersecurity oraz technologiach zbrojeniowych</strong>.
        </p>

        <p class="mb-6">
            Działając w samym sercu bałtyckiego hubu innowacji i bezpieczeństwa NATO (Estonia), 
            łączymy lokalną wiedzę operacyjną z globalnym zasięgiem. Wspieramy naszych klientów 
            w nawigowaniu po złożonych strukturach decyzyjnych, zabezpieczając ich interesy 
            na rynkach UE, Azji Wschodniej oraz Bliskiego Wschodu.
        </p>

        <h3 class="text-xl font-bold mt-12 mb-4 text-slate-900 border-l-4 border-blue-600 pl-4">
            Obszary Operacyjne
        </h3>

        <div class="grid md:grid-cols-2 gap-8 my-8">
            <div class="card p-6 bg-slate-50 border border-slate-200 rounded-lg">
                <h4 class="font-bold text-slate-900 mb-2 uppercase text-sm">Strategic Intelligence</h4>
                <p class="text-sm">Głęboka analiza rynkowa, identyfikacja zagrożeń oraz weryfikacja partnerów biznesowych w regionach wysokiego ryzyka.</p>
            </div>
            <div class="card p-6 bg-slate-50 border border-slate-200 rounded-lg">
                <h4 class="font-bold text-slate-900 mb-2 uppercase text-sm">Defence Lobbying</h4>
                <p class="text-sm">Budowanie trwałych relacji z organami administracji publicznej oraz reprezentacja interesów w strukturach międzynarodowych.</p>
            </div>
        </div>

        <p class="mt-8 italic text-slate-600">
            Współpraca z ALNAIR OU to gwarancja najwyższych standardów etycznych, 
            poufności oraz precyzji dostarczanych danych wywiadowczych.
        </p>
    </div>
</BaseLayout>
