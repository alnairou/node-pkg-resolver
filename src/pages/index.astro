---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Root (/) to polska wersja językowa ALNAIR OU
const lang = "pl";
---

<BaseLayout title={`ALNAIR OU | ${SITE_TITLE}`} description={SITE_DESCRIPTION} lang={lang}>
	<section class="hero-container">
		<div class="hero-content">
			<span class="badge">Global Strategic Intelligence & Lobbying</span>
			<h1>ALNAIR OU <br/><span class="subtitle">(Defence / Intelligence)</span></h1>
			<p class="lead">
				Zapewniamy przewagę informacyjną i wsparcie operacyjne dla sektorów obronnych, 
				cyberbezpieczeństwa oraz inwestycji strategicznych w regionach wysokiego ryzyka.
			</p>
			<div class="actions">
				<a href="/about" class="btn-primary shadow-lg">Kompetencje Strategiczne</a>
				<a href="/contact" class="btn-secondary">Kontakt Operacyjny</a>
			</div>
		</div>
	</section>

	<section class="features-grid">
		<div class="feature-item">
			<div class="icon-placeholder">🛡️</div>
			<h3>Intelligence</h3>
			<p>Analiza zagrożeń i wywiad gospodarczy na rynkach NATO, Azji Wschodniej i Bliskiego Wschodu.</p>
		</div>
		<div class="feature-item">
			<div class="icon-placeholder">⚖️</div>
			<h3>Lobbying</h3>
			<p>Budowanie relacji z decydentami i reprezentacja interesów w strukturach międzynarodowych.</p>
		</div>
		<div class="feature-item">
			<div class="icon-placeholder">🛰️</div>
			<h3>Defence</h3>
			<p>Doradztwo w obrocie technologiami zbrojeniowymi oraz wsparcie projektów militarnych.</p>
		</div>
	</section>
</BaseLayout>

<style>
	.hero-container {
		padding: 6rem 1rem;
		text-align: center;
		background: radial-gradient(circle at top, #f8fafc 0%, #ffffff 100%);
	}
	.hero-content {
		max-width: 900px;
		margin: 0 auto;
	}
	.badge {
		color: #2563eb;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.85rem;
		display: block;
		margin-bottom: 1rem;
	}
	h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 900;
		line-height: 1;
		margin-bottom: 1.5rem;
		color: #020617;
		text-transform: uppercase;
		letter-spacing: -0.02em;
	}
	.subtitle {
		font-size: 0.5em;
		color: #64748b;
		vertical-align: middle;
	}
	.lead {
		font-size: 1.25rem;
		color: #475569;
		margin-bottom: 3rem;
		line-height: 1.6;
	}
	.actions {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
	}
	.btn-primary {
		background: #020617;
		color: white;
		padding: 1rem 2.5rem;
		border-radius: 4px;
		font-weight: 800;
		text-decoration: none;
		transition: transform 0.2s;
	}
	.btn-primary:hover { transform: translateY(-2px); }
	
	.btn-secondary {
		border: 2px solid #020617;
		color: #020617;
		padding: 1rem 2.5rem;
		border-radius: 4px;
		font-weight: 800;
		text-decoration: none;
	}
	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		padding: 5rem 1.5rem;
		max-width: 1200px;
		margin: 0 auto;
	}
	.feature-item {
		padding: 3rem 2rem;
		border-radius: 4px;
		background: #ffffff;
		border-left: 4px solid #020617;
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
	}
	.icon-placeholder { font-size: 2rem; margin-bottom: 1rem; }
	.feature-item h3 {
		font-weight: 900;
		margin-bottom: 1rem;
		color: #020617;
		text-transform: uppercase;
	}

	@media (max-width: 640px) {
		.actions { flex-direction: column; }
	}
</style>
